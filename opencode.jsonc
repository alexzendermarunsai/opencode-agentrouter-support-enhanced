{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "agentrouter": {
      "name": "AgenRouter",
      "npm": "@ai-sdk/openai-compatible",

      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "dummy"
      },

      "models": {
        "deepseek-v4-pro": {
          "name": "deepseek v4 pro",
          "id": "deepseek-v4-pro"
        },
      
        "deepseek-v4-flash": {
          "name": "deepseek v4 flash",
          "id": "deepseek-v4-flash"
        },
        "glm-5.1": {
          "name": "glm 5.1",
          "id": "glm-5.1"
        }
      }
    }
  }
}
